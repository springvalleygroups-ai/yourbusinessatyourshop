rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /selfies/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 2 * 1024 * 1024; // max 2MB selfie
    }
    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'vendor' && request.resource.size < 5 * 1024 * 1024; // max 5MB product images
    }
  }
}
