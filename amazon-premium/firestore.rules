rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users rules
    match /users/{userId} {
      allow create: if true; // anyone can register
      allow update, delete: if isOwner(userId) || isAdmin();
      // Sensitive Aadhaar and selfie data can only be read by Owner or Admin
      allow read: if isOwner(userId) || isAdmin();
    }

    // Products rules
    match /products/{productId} {
      allow read: if resource.data.approvedByAdmin == true || isAdmin() || (request.auth != null && resource.data.vendorId == request.auth.uid);
      allow create: if request.auth != null && request.auth.token.role == 'vendor';
      allow update: if isAdmin() || (request.auth != null && resource.data.vendorId == request.auth.uid);
      allow delete: if isAdmin() || (request.auth != null && resource.data.vendorId == request.auth.uid);
    }

    // Orders rules
    match /orders/{orderId} {
      allow create: if true; // customers or guest checkouts can place orders
      allow read: if isAdmin() || (request.auth != null && (resource.data.customerId == request.auth.uid || resource.data.vendorId == request.auth.uid));
      allow update: if isAdmin() || (request.auth != null && resource.data.vendorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Reviews rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
  }
}
